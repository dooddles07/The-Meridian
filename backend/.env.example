# ─────────────────────────────────────────────────────────────────────────────
# The Meridian — PORTFOLIO DEMO
#
# The demo needs NO configuration. `npm start` serves the static frontend and the
# whole app runs in the browser with seeded data (no database, CRM, or webhooks).
# Copy this file to `.env` only if you want to change the port.
# ─────────────────────────────────────────────────────────────────────────────

# Port the static server listens on (default 3000).
PORT=3000

# The variables below belong to the ORIGINAL production backend (kept under
# ./backend as reference only). They are intentionally left blank — the demo never
# reads them and makes no external connection. Do not put real credentials here.
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:3000
JWT_SECRET=
MONGO_URL=
GHL_API_KEY=
GHL_LOCATION_ID=
