# ─────────────────────────────────────────────────────────────────────────────
# The Lumina — local dev config
#
# Copy this file to backend/.env and fill in real values. Resident/management/
# guardhouse login and the resident portal's own data are real (Mongo-backed,
# JWT sessions) — the other resident features + all of management/guardhouse's
# data views still run on the client-side mock (public/js/client-backend.js),
# since those were built against a GoHighLevel CRM integration this project
# doesn't have configured.
# ─────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# Required — the server refuses to start without a real, 32+ char secret.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Required for any of this to persist — a MongoDB connection string (Atlas free
# tier, Railway's MongoDB service, or any other Mongo instance).
MONGO_URL=

# Optional — pre-provisions management/guardhouse staff accounts (JSON array of
# {username, password (bcrypt hash recommended), displayName}). No self-signup
# for these roles by design; only residents can register themselves.
LUMINA_MANAGEMENT=
LUMINA_GUARDHOUSE=

# Optional — enables the "forgot password" email. Without it, the reset link is
# logged to the console instead (fine for local dev). Get a free key at
# resend.com — the sandbox sender only delivers to your own Resend account
# email until you verify a real domain there.
RESEND_API_KEY=

# Used to build the link in password-reset emails. Set this to your real
# deployed URL (e.g. https://your-app.up.railway.app) in production.
PUBLIC_APP_URL=http://localhost:3000

# Optional — GoHighLevel CRM integration (contact sync on resident login/signup;
# nothing breaks without it, contact_id just stays empty).
GHL_API_KEY=
GHL_LOCATION_ID=
